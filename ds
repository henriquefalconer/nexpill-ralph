#!/usr/bin/env bash
# ds — run a command inside the project's Docker sandbox.
# Usage: ./ds <cmd> [args...]

set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd -P)"
SANDBOX_NAME="claude-$(basename -- "$ROOT")"

if ! command -v docker >/dev/null 2>&1; then
    echo "docker not found — install Docker first (see README Setup section)." >&2
    exit 1
fi

QUOTED_ROOT=$(printf '%q' "$ROOT")
QUOTED_CMD=$(printf '%q ' "$@")

# Print exactly what will run
printf "Running $* in $SANDBOX_NAME sandbox:\n"
printf '\n'

exec docker sandbox exec -it "$SANDBOX_NAME" sh -c "cd $QUOTED_ROOT && $QUOTED_CMD"
