#!/usr/bin/env bash
# ds — run a command inside the project's sandbox.
# Usage:
#   ./ds               # create/open the sandbox with the claude agent in the repo root
#   ./ds <cmd> [args]  # exec a command inside the already-running sandbox
#
# Prefers `docker sandbox` (Docker Desktop 4.50+, macOS/Windows). Falls back to
# the standalone `sbx` CLI (`docker-sbx` package, Linux) which exposes the same
# run/exec subcommands.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd -P)"
SANDBOX_NAME="claude-$(basename -- "$ROOT")"

# Pick the sandbox driver: Docker Desktop's built-in command, else standalone sbx.
if command -v docker >/dev/null 2>&1 && docker sandbox --help >/dev/null 2>&1; then
    SANDBOX_CMD=(docker sandbox)
elif command -v sbx >/dev/null 2>&1; then
    SANDBOX_CMD=(sbx)
else
    echo "No sandbox driver found." >&2
    echo "  macOS/Windows: install Docker Desktop 4.50+ (provides 'docker sandbox')." >&2
    echo "  Linux:         install 'docker-sbx' (provides 'sbx')." >&2
    echo "See the README Setup section." >&2
    exit 1
fi

# No arguments → create/open the sandbox with the claude agent in this directory.
# First run builds the image; subsequent runs attach to the existing sandbox.
if [ $# -eq 0 ]; then
    printf "Opening %s sandbox with claude agent (via %s run):\n\n" "$SANDBOX_NAME" "${SANDBOX_CMD[*]}"
    exec "${SANDBOX_CMD[@]}" run claude "$ROOT"
fi

QUOTED_ROOT=$(printf '%q' "$ROOT")
QUOTED_CMD=$(printf '%q ' "$@")

printf "Running %s in %s sandbox (via %s):\n\n" "$*" "$SANDBOX_NAME" "${SANDBOX_CMD[*]}"

exec "${SANDBOX_CMD[@]}" exec -it "$SANDBOX_NAME" sh -c "cd $QUOTED_ROOT && $QUOTED_CMD"
