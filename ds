#!/usr/bin/env bash
# ds — run ralph inside a Docker sandbox via `docker sandbox exec`.
# Usage: ./ds [plan|security] [max_iter] [--goal "..."] [--ref-branch ...]
#        ./ds shell          # open an interactive shell in the sandbox
#        ./ds login          # run `claude login` in the sandbox (once)

set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd -P)"
SANDBOX_NAME="claude-$(basename -- "$ROOT")"

if ! command -v docker >/dev/null 2>&1; then
    echo "docker not found — install Docker first (see README Setup section)." >&2
    exit 1
fi

case "${1:-}" in
    shell) shift; set -- bash "$@" ;;
    login) shift; set -- claude login "$@" ;;
    *)     set -- ./ralph/ralph.sh "$@" ;;
esac

INNER_CMD="cd \"$ROOT\" && $*"

printf 'Running %s in %s sandbox:\n\n' "$*" "$SANDBOX_NAME"
exec docker sandbox exec -it "$SANDBOX_NAME" sh -c "$INNER_CMD"
