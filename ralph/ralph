#!/usr/bin/env bash

# Ralph Wiggum - Long-running AI agent loop
# Usage: ./ralph [plan|security|build|kill] [max_iterations] [--goal <text>] [--ref-branch <branch>]
#
# Examples:
#   ./ralph                                # Build mode, unlimited
#   ./ralph 20                             # Build mode, max 20
#   ./ralph plan --goal "feature"          # Plan mode, 1 iter (default)
#   ./ralph security --ref-branch develop    # Security mode, 1 iter (default)
#   ./ralph kill                           # SIGINT every running claude & ralph process

set -euo pipefail

# ANSI escape codes usage: only applied before the `# Select model` block below.
GREEN_BOLD="\033[1;38;2;40;254;20m"
YELLOW_BOLD="\033[1;33m"
RED_BOLD="\033[1;31m"
RESET="\033[0m"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)
TODO_FILE="$SCRIPT_DIR/todo.md"
PROGRESS_FILE="$SCRIPT_DIR/progress.txt"
ARCHIVE_DIR="$SCRIPT_DIR/archive"
LAST_BRANCH_FILE="$SCRIPT_DIR/.last-branch"
LOG_FILE="$SCRIPT_DIR/ralph.log"

ITERATION_TIMEOUT="${ITERATION_TIMEOUT:-1800}"  # 30min of ralph/progress.txt idle time (override via env)
WATCHDOG_POLL_INTERVAL="${WATCHDOG_POLL_INTERVAL:-5}"  # how often the stall watchdog checks mtime
LOG_MAX_BYTES="${LOG_MAX_BYTES:-$((5 * 1024 * 1024 * 1024))}"  # 5 GiB cap on ralph.log (override via env)
API_ERROR_MAX_RETRIES="${API_ERROR_MAX_RETRIES:-3}"       # per-iteration retry budget for transient API errors (401/429/5xx)
API_ERROR_BACKOFF_SECONDS="${API_ERROR_BACKOFF_SECONDS:-60}"  # sleep between API-error retries
TAIL_PID=""

cleanup() {
  [ -n "${TAIL_PID:-}" ] && kill "$TAIL_PID" 2>/dev/null || true
}
trap 'cleanup' EXIT
trap 'echo "Received interrupt, cleaning up..."; exit 130' INT
trap 'echo "Received termination signal, cleaning up..."; exit 143' TERM

# Run "$@" in the background, capturing its stdout+stderr. Kill it if
# $PROGRESS_FILE goes unmodified for $ITERATION_TIMEOUT seconds (stall).
# Prints captured output on stdout (so callers can `OUTPUT=$(...)`); also
# tees live to stderr so the user sees progress.
# Returns: 124 if killed for stall, else the command's own exit code.
run_with_stall_watchdog() {
    local outfile stall_sentinel cmd_pid watchdog_pid tail_pid cmd_exit=0
    outfile=$(mktemp)
    stall_sentinel=$(mktemp -u)

    "$@" > "$outfile" 2>&1 &
    cmd_pid=$!

    tail -n +1 -f --pid="$cmd_pid" "$outfile" >&2 &
    tail_pid=$!

    (
        baseline=$(date +%s)
        while kill -0 "$cmd_pid" 2>/dev/null; do
            sleep "$WATCHDOG_POLL_INTERVAL"
            now=$(date +%s)
            mtime=$(stat -c %Y "$PROGRESS_FILE" 2>/dev/null || echo "$baseline")
            last=$(( mtime > baseline ? mtime : baseline ))
            if (( now - last >= ITERATION_TIMEOUT )); then
                touch "$stall_sentinel"
                kill -TERM "$cmd_pid" 2>/dev/null || true
                sleep 2
                kill -KILL "$cmd_pid" 2>/dev/null || true
                break
            fi
        done
    ) &
    watchdog_pid=$!

    wait "$cmd_pid" 2>/dev/null || cmd_exit=$?
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true
    wait "$tail_pid" 2>/dev/null || true

    cat "$outfile"
    rm -f "$outfile"

    if [ -f "$stall_sentinel" ]; then
        rm -f "$stall_sentinel"
        return 124
    fi
    return "$cmd_exit"
}

# Trim $1 to its last $2 bytes when it exceeds that cap. The first surviving
# line may be partially truncated.
rotate_log() {
    local file="$1" max="$2" size tmp
    [ -f "$file" ] || return 0
    size=$(stat -c %s "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt "$max" ]; then
        tmp=$(mktemp)
        tail -c "$max" "$file" > "$tmp"
        mv "$tmp" "$file"
    fi
}

# When sourced with RALPH_SOURCE_ONLY=1, stop before main logic so tests can
# exercise run_with_stall_watchdog in isolation.
if [ "${RALPH_SOURCE_ONLY:-}" = "1" ] && [ "${BASH_SOURCE[0]}" != "${0}" ]; then
    return 0
fi

# ────────────────────────────────────────────────
# Parse flags & positional arguments
# ────────────────────────────────────────────────

GOAL_TEXT=""
REF_BRANCH=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --goal)
            shift
            [[ $# -eq 0 ]] && { echo -e "${RED_BOLD}Error: --goal requires a value${RESET}"; exit 1; }
            GOAL_TEXT="$1"
            shift
            ;;
        --ref-branch)
            shift
            [[ $# -eq 0 ]] && { echo -e "${RED_BOLD}Error: --ref-branch requires a value${RESET}"; exit 1; }
            REF_BRANCH="$1"
            shift
            ;;
        *)
            POSITIONAL+=("$1")
            shift
            ;;
    esac
done

set -- "${POSITIONAL[@]:-}"

# ────────────────────────────────────────────────
# Kill mode: SIGINT every running claude process, then SIGTERM every other
# ralph invocation. No prompt file, no loop, no branch checks — just a
# panic button. Excludes this process (and its parent shell) so we don't
# kill ourselves before the claude signal propagates.
# ────────────────────────────────────────────────

if [ "${1:-}" = "kill" ]; then
    echo -e "Sending SIGINT to all claude processes..."
    if pkill -INT -f claude; then
        echo -e "Signal delivered."
    else
        echo -e "No matching claude processes found."
    fi
    sleep 1
    echo -e "Sending SIGTERM to other ralph invocations..."
    others=$(pgrep -f '[/ ]ralph( |$)' | grep -vx "$$" || true)
    if [ -n "$others" ]; then
        echo "$others" | xargs kill -TERM 2>/dev/null || true
        echo -e "Signal delivered."
    else
        echo -e "No other ralph invocations found."
    fi
    exit 0
fi

# ────────────────────────────────────────────────
# Mode, iterations, prompt file
# ────────────────────────────────────────────────

if [ "${1:-}" = "plan" ]; then
    MODE="plan"
    shift
    MAX_ITERATIONS="${1:-1}"
    [[ "$MAX_ITERATIONS" =~ ^[0-9]+$ ]] && shift || MAX_ITERATIONS=1
elif [ "${1:-}" = "security" ]; then
    MODE="security"
    shift
    MAX_ITERATIONS="${1:-1}"
    [[ "$MAX_ITERATIONS" =~ ^[0-9]+$ ]] && shift || MAX_ITERATIONS=1
elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    MODE="build"
    MAX_ITERATIONS="$1"
    shift
else
    MODE="build"
    MAX_ITERATIONS=0
fi

# Plan mode requires --goal
if [ "$MODE" = "plan" ]; then
    GOAL_TEXT="${GOAL_TEXT:?Usage: ./ralph plan --goal <branch>}"
fi

# Security mode requires --ref-branch
if [ "$MODE" = "security" ]; then
    REF_BRANCH="${REF_BRANCH:?Usage: ./ralph security --ref-branch <branch>}"
fi

# Validate prompt file
PROMPT_FILE="$SCRIPT_DIR/prompt-${MODE}.md"
if [ ! -f "$PROMPT_FILE" ]; then
    echo -e "${RED_BOLD}Error: $PROMPT_FILE not found${RESET}"
    exit 1
fi

# Select model
if [ "$MODE" = "build" ]; then
    MODEL="sonnet"
else
    MODEL="opus"
fi

CURRENT_BRANCH=$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)

# ────────────────────────────────────────────────
# Archive previous run if branch changed
# ────────────────────────────────────────────────

if [ -f "$LAST_BRANCH_FILE" ]; then
  LAST_BRANCH=$(cat "$LAST_BRANCH_FILE" 2>/dev/null || echo "")
  if [ -n "$LAST_BRANCH" ] && [ "$CURRENT_BRANCH" != "$LAST_BRANCH" ]; then
    DATE=$(date +%Y-%m-%d)
    FOLDER_NAME=$(echo "$LAST_BRANCH" | sed 's|^ralph/||' | tr '/' '-')
    ARCHIVE_FOLDER="$ARCHIVE_DIR/$DATE-$FOLDER_NAME"

    echo "Archiving previous run: $LAST_BRANCH"
    mkdir -p "$ARCHIVE_FOLDER"
    [ -f "$TODO_FILE" ] && cp "$TODO_FILE" "$ARCHIVE_FOLDER/"
    [ -f "$PROGRESS_FILE" ] && cp "$PROGRESS_FILE" "$ARCHIVE_FOLDER/"
    echo "   Archived to: $ARCHIVE_FOLDER"
  fi
fi

echo "$CURRENT_BRANCH" > "$LAST_BRANCH_FILE"

# ────────────────────────────────────────────────
# Reset progress file and start tailing (sync stdout)
# ────────────────────────────────────────────────

: > "$PROGRESS_FILE"
tail -f "$PROGRESS_FILE" &
TAIL_PID=$!

# ────────────────────────────────────────────────
# Header
# ────────────────────────────────────────────────

if [ "$MAX_ITERATIONS" -gt 0 ]; then
    echo "Launching Ralph - Mode: $MODE - Branch: $CURRENT_BRANCH - Max iterations: $MAX_ITERATIONS"
else
    echo "Launching Ralph - Mode: $MODE - Branch: $CURRENT_BRANCH - Max iterations: unlimited"
fi

# ────────────────────────────────────────────────
# Main loop
# ────────────────────────────────────────────────

ITERATION=0
API_RETRIES_USED=0

while true; do
    if [ "$MAX_ITERATIONS" -gt 0 ] && [ "$ITERATION" -ge "$MAX_ITERATIONS" ]; then
        echo ""
        echo "Ralph reached max iterations ($MAX_ITERATIONS) without completing."
        sleep 1
        cleanup
        trap - EXIT
        exit 1
    fi

    CURRENT_ITER=$((ITERATION + 1))
    START_TIME=$(date +%s)
    if [ "$MAX_ITERATIONS" -gt 0 ]; then
        ITER_LABEL="$CURRENT_ITER of $MAX_ITERATIONS"
    else
        ITER_LABEL="$CURRENT_ITER"
    fi

    echo ""
    echo "Launched Ralph. Await for messages."
    echo ""

    TIMEOUT_EXIT=0

    # Substitute placeholders via bash parameter expansion (sed-safe: the
    # values can contain /, &, \, newlines — all fine here). Write to a
    # temp file so claude reads the fully rendered prompt from stdin.
    PROMPT_CONTENT=$(cat "$PROMPT_FILE"; printf x); PROMPT_CONTENT=${PROMPT_CONTENT%x}
    case "$MODE" in
        plan)
            PROMPT_CONTENT="${PROMPT_CONTENT//\[project-specific goal\]/$GOAL_TEXT}"
            PROMPT_CONTENT="${PROMPT_CONTENT//\[ralph-iteration\]/$CURRENT_ITER}"
            ;;
        security)
            PROMPT_CONTENT="${PROMPT_CONTENT//\[ref-branch\]/$REF_BRANCH}"
            PROMPT_CONTENT="${PROMPT_CONTENT//\[ralph-iteration\]/$CURRENT_ITER}"
            ;;
        *)
            PROMPT_CONTENT="${PROMPT_CONTENT//\[ralph-iteration\]/$CURRENT_ITER}"
            ;;
    esac
    PROMPT_TMP=$(mktemp)
    printf '%s' "$PROMPT_CONTENT" > "$PROMPT_TMP"

    # IS_SANDBOX=1 lets claude accept --dangerously-skip-permissions when
    # running as root (e.g. inside the Linux Docker sandbox). Harmless for
    # non-root invocations — claude only checks the flag when getuid()==0.
    rotate_log "$LOG_FILE" "$LOG_MAX_BYTES"
    printf '\n=== Iteration %s — %s ===\n' "$CURRENT_ITER" "$(date -u +%FT%TZ)" >> "$LOG_FILE"
    OUTPUT=$(run_with_stall_watchdog bash -c \
        'set -o pipefail; IS_SANDBOX=1 claude --dangerously-skip-permissions --print --model "$2" --verbose --output-format stream-json < "$1" 2>&1 | tee -a "$3"' \
        _ "$PROMPT_TMP" "$MODEL" "$LOG_FILE" 2>/dev/null) || TIMEOUT_EXIT=$?
    rm -f "$PROMPT_TMP"

    # Detect stall timeout: watchdog returns 124 when it killed the child for progress.txt inactivity.
    if [ "$TIMEOUT_EXIT" -eq 124 ]; then
        echo ""
        echo "Ralph iteration $CURRENT_ITER timed out after ralph/progress.txt updates idle for ${ITERATION_TIMEOUT}s."
        echo "Check $PROGRESS_FILE for status."
        exit 1
    fi

    # Extract promise signal (NEXT or COMPLETE) from claude's reply.
    PROMISE=$(echo "$OUTPUT" | grep -oE "<promise>(NEXT|COMPLETE)</promise>" | tail -1 || true)
    if [ -z "$PROMISE" ]; then
        # Commit anything written to progress.txt before the failure so the
        # working tree stays clean whether we retry or bail out.
        git add ralph/.last-branch ralph/progress.txt ralph/todo.md 2>/dev/null || true
        git commit -m "commit progress.txt, .last-branch and todo.md files (aborted iter $CURRENT_ITER)" >/dev/null 2>&1 || true

        # Parse the final stream-json result frame for an Anthropic API error
        # code + message. Successful iterations emit "api_error_status":null
        # (regex misses, $API_ERR stays empty); transient failures (401/429/
        # 5xx) emit a numeric code we can retry on. See ralph/ralph.log
        # iteration 16 for the canonical failure shape.
        RESULT_LINE=$(echo "$OUTPUT" | grep '"type":"result"' | tail -1 || true)
        API_ERR=$(echo "$RESULT_LINE" | grep -oE '"api_error_status":[0-9]+' | grep -oE '[0-9]+$' || true)
        API_ERR_MSG=$(echo "$RESULT_LINE" | sed -n 's/.*"result":"\(.*\)","stop_reason":.*/\1/p' | sed 's/\\"/"/g')

        if [ -n "$API_ERR" ]; then
            echo ""
            echo "Anthropic API error $API_ERR:"
            if [ -n "$API_ERR_MSG" ]; then echo "  $API_ERR_MSG"; fi
        fi

        if [ -n "$API_ERR" ] && [ "$API_ERROR_MAX_RETRIES" -gt 0 ] && [ "$API_RETRIES_USED" -lt "$API_ERROR_MAX_RETRIES" ]; then
            API_RETRIES_USED=$((API_RETRIES_USED + 1))
            echo "Ralph iteration $CURRENT_ITER: retry $API_RETRIES_USED/$API_ERROR_MAX_RETRIES after ${API_ERROR_BACKOFF_SECONDS}s."
            sleep "$API_ERROR_BACKOFF_SECONDS"
            continue   # retry the same iteration slot
        fi

        echo ""
        if [ -n "$API_ERR" ]; then
            echo "Ralph iteration $CURRENT_ITER aborted after $API_RETRIES_USED API-error retries."
        else
            echo "Ralph finished without completing all tasks."
        fi
        echo "Check $PROGRESS_FILE for status."
        exit 1
    fi

    # Valid promise landed, clear the per-slot retry budget for the next iter.
    API_RETRIES_USED=0

    printf '\n%s\n' "$PROMISE" >> "$PROGRESS_FILE"

    # Commit remaining progress.txt, .last-branch and todo.md files
    git add ralph/.last-branch ralph/progress.txt ralph/todo.md
    git commit -m "commit progress.txt, .last-branch and todo.md files" >/dev/null 2>&1 || true

    # Push changes after each iteration (non-fatal if it fails)
    git -C "$REPO_ROOT" push origin "$CURRENT_BRANCH" 2>/dev/null || \
        git -C "$REPO_ROOT" push -u origin "$CURRENT_BRANCH" 2>/dev/null || true

    # Completion check: <promise>COMPLETE</promise> ends the loop.
    if [ "$PROMISE" = "<promise>COMPLETE</promise>" ]; then
        echo ""
        echo "Ralph signaled completion at iteration $CURRENT_ITER."
        sleep 1
        cleanup
        trap - EXIT
        exit 0
    fi

    ITERATION=$((ITERATION + 1))
    echo ""
    echo "Iteration $CURRENT_ITER complete. Continuing..."
    sleep 2
done
